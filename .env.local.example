# Microsoft Entra ID (Azure AD) Configuration
# Create an app registration in Azure Portal and configure these values

# Client ID from your Entra ID app registration
NEXT_PUBLIC_MSAL_CLIENT_ID=your-client-id-here

# Authority URL
# Use 'common' for multi-tenant (allows any Azure AD tenant to sign in)
# OR use your specific tenant ID: https://login.microsoftonline.com/{tenant-id}
NEXT_PUBLIC_MSAL_AUTHORITY=https://login.microsoftonline.com/common

# Redirect URI (must match the redirect URI configured in your app registration)
NEXT_PUBLIC_MSAL_REDIRECT_URI=http://localhost:3000

# Cloud environment (global, usgov, usgovdod, germany, china)
NEXT_PUBLIC_CLOUD_ENVIRONMENT=global

# Optional: Default tenant ID to pre-populate in the wizard
# Leave blank to allow users to enter any tenant ID
# NEXT_PUBLIC_DEFAULT_TENANT_ID=
